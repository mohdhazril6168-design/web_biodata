<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Personal Website</title>

<!-- Font & Icon -->
<link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}

body {
    display: flex;
    background: #f4f6f9;
}

/* Sidebar */
.sidebar {
    width: 250px;
    background: linear-gradient(180deg, #2c3e50, #1a252f);
    color: white;
    height: 100vh;
    padding: 20px;
    position: fixed;
}

.sidebar h2 {
    text-align: center;
    margin-bottom: 20px;
}

.sidebar a {
    display: block;
    color: white;
    padding: 12px;
    margin: 8px 0;
    text-decoration: none;
    border-radius: 8px;
    transition: 0.3s;
}

.sidebar a:hover {
    background: #1abc9c;
    transform: translateX(5px);
}

/* Content */
.content {
    margin-left: 250px;
    padding: 30px;
    width: 100%;
}

/* Card */
.card {
    background: white;
    padding: 25px;
    border-radius: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    margin-bottom: 20px;
    animation: fade 0.5s;
}

/* Profile */
.profile {
    text-align: center;
}

.profile img {
    width: 120px;
    border-radius: 50%;
    margin-bottom: 15px;
}

/* Skill Bar */
.skill {
    margin: 10px 0;
}

.skill-bar {
    background: #ddd;
    border-radius: 20px;
    overflow: hidden;
}

.skill-fill {
    height: 20px;
    background: #1abc9c;
    text-align: right;
    padding-right: 5px;
    color: white;
    font-size: 12px;
}

/* Pages */
.page {
    display: none;
}

.active {
    display: block;
}

/* Animasi */
@keyframes fade {
    from {opacity: 0; transform: translateY(10px);}
    to {opacity: 1; transform: translateY(0);}
}

/* Footer */
footer {
    text-align: center;
    margin-top: 20px;
    color: gray;
}

/* Responsive */
@media (max-width: 768px) {
    .sidebar {
        position: relative;
        width: 100%;
        height: auto;
    }

    .content {
        margin-left: 0;
    }
}
</style>
</head>

<body>

<!-- Sidebar -->
<div class="sidebar">
    <h2>My Profile</h2>

    <a href="#" onclick="showPage('home')"><i class="fa fa-user"></i> Home</a>
    <a href="#" onclick="showPage('hobby')"><i class="fa fa-heart"></i> Hobby</a>
    <a href="#" onclick="showPage('pendidikan')"><i class="fa fa-school"></i> Pendidikan</a>
    <a href="#" onclick="showPage('kontak')"><i class="fa fa-phone"></i> Kontak</a>
</div>

<!-- Content -->
<div class="content">

<!-- HOME -->
<div id="home" class="page active">
    <div class="card profile">
        <img src="foto.jpg" alt="">
        <h2>Mohd Hazril</h2>
        <p>Mahasiswa | Web Developer Pemula</p>
    </div>

    <div class="card">
        <h3>Tentang Saya</h3>
        <p>Saya adalah mahasiswa yang sedang belajar pemrograman web dan ingin menjadi developer profesional.</p>
    </div>

    <div class="card">
        <h3>Skill</h3>

        <div class="skill">
            <p>HTML</p>
            <div class="skill-bar">
                <div class="skill-fill" style="width:80%">80%</div>
            </div>
        </div>

        <div class="skill">
            <p>CSS</p>
            <div class="skill-bar">
                <div class="skill-fill" style="width:70%">70%</div>
            </div>
        </div>

        <div class="skill">
            <p>JavaScript</p>
            <div class="skill-bar">
                <div class="skill-fill" style="width:60%">60%</div>
            </div>
        </div>
    </div>
</div>

<!-- HOBBY -->
<div id="hobby" class="page">
    <div class="card">
        <h2>Hobby Saya</h2>
        <ul>
            <li>🏃 Olahraga</li>
            <li>🏔️ Mendaki Gunung</li>
            <li>💻 Ngoding</li>
        </ul>
    </div>
</div>

<!-- PENDIDIKAN -->
<div id="pendidikan" class="page">
    <div class="card">
        <h2>Riwayat Pendidikan</h2>
        <ul>
            <li>SD</li>
            <li>SMP</li>
            <li>SMA</li>
            <li>Kuliah (Saat ini)</li>
        </ul>
    </div>
</div>

<!-- KONTAK -->
<div id="kontak" class="page">
    <div class="card">
        <h2>Kontak</h2>
        <p><i class="fa fa-envelope"></i> email@gmail.com</p>
        <p><i class="fa fa-phone"></i> 08123456789</p>
        <p><i class="fa fa-instagram"></i> @username</p>
    </div>
</div>

<footer>
    <p>© 2026 Mohd Hazril</p>
</footer>

</div>

<script>
function showPage(pageId) {
    let pages = document.querySelectorAll('.page');
    pages.forEach(p => p.classList.remove('active'));

    document.getElementById(pageId).classList.add('active');
}
</script>

</body>
</html>